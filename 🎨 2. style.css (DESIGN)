body {
  font-family: Arial;
  background: #f4f6f9;
  text-align: center;
}

.form {
  margin: 20px;
}

input, select, button {
  padding: 10px;
  margin: 5px;
}

table {
  width: 90%;
  margin: auto;
  border-collapse: collapse;
  background: white;
}

th, td {
  border: 1px solid #ddd;
  padding: 10px;
}

button {
  background: blue;
  color: white;
  border: none;
  cursor: pointer;
}

.delete {
  background: red;
}
